# Godot 4 auto-generated files
.godot/
.import/
export.cfg

# export_presets.cfg is intentionally versioned so local and CI exports use
# the same platform settings. Secrets belong in .godot/export_credentials.cfg.

# Mono / .NET (unused, but safe to ignore)
.mono/
data_*/

# Exported test builds (binaries are not committed)
builds/
dist/

# Python tool caches
__pycache__/
*.py[cod]

# Historical working notes are kept locally, not published with the project.
docs/archive/

# Cloud-sync conflict duplicates (OneDrive/Drive "Name clash" copies).
# Specific to sync artifacts; does not hide real project files.
*Name clash*

# OS / editor cruft
*.tmp
Thumbs.db
.DS_Store
