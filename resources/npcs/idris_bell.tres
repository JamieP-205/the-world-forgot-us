[ext_resource type="Script" path="res://scripts/npcs/world_npc_profile.gd" id="1_profile"]
[ext_resource type="Texture2D" path="res://assets/generated/npcs/idris_bell_walk.png" id="2_atlas"]

[resource]
script = ExtResource("1_profile")
npc_id = &"idris"
display_name = "Idris Bell"
role = "Shelter carpenter and Imogen's older brother"
story_reason = "Idris strips Cullbrook's maintenance bays for safe timber and ventilation parts. He left Ashmere after an argument with Imogen and has not learned whether she survived the clinic."
home_region = &"cullbrook"
service_id = &"shelter_repair"
service_name = "shelter repair"
service_description = "Reinforces Railhome's bunks and records a durable recovery bonus for future rests."
service_flag = &"npc_service_idris_repair"
service_choice = "HELP IDRIS REINFORCE THE BUNKS"
service_notice = "Idris braces the bunks and opens a clean ventilation run. Railhome can recover from harsher nights."
helped_flag = &"npc_idris_helped"
ignored_flag = &"npc_idris_ignored"
voice_signature = "measured joiner's observations that circle family questions he cannot ask directly"
greeting = "That board is load-bearing because I say it is, not because the rust agrees."
intro_lines = Array[String](["IDRIS - The north bay has enough dry timber for six bunks. I only have two shoulders.", "If you came through Ashmere, tell me one thing: did Imogen still tap her pencil when she was frightened?"])
helped_lines = Array[String](["IDRIS - I built Imogen a medicine shelf. Did not put her name on it. She knows my joints."])
ignored_lines = Array[String](["IDRIS - I carried what I could. Left the long braces. Hope your carriage never needs them."])
service_lines = Array[String](["IDRIS - Hold this square. Homes fail at corners first; people usually fail somewhere quieter."])
anchor_lines = {"clinic": "IDRIS - Keep the clinic alive. Imogen will pretend that is not the same as keeping her alive.", "radio": "IDRIS - A good shelter has two exits. Give your radio route the same courtesy.", "witness": "IDRIS - Ask Imogen about the pencil. A machine will call it an irrelevant detail.", "copy": "IDRIS - If it sounds like my sister, ask it which cupboard she kicked through at twelve."}
strategy_lines = {"restore": "IDRIS - Restore what you can inspect from both sides.", "sever": "IDRIS - A clean cut still needs a cap, or the weather gets in.", "mesh": "IDRIS - Small shelters share loads better than one grand roof. Networks might too."}
help_choice = "LOAD THE RAILHOME BRACES"
ignore_choice = "LEAVE HIM THE MAINTENANCE BAY"
sprite_atlas = ExtResource("2_atlas")
silhouette_signature = "tall uneven shoulders / cream cross-back harness / mallet / folding rule"
visual_notes = "Idris's height, lowered carrying shoulder and carpenter harness are authored into every direction; his mallet and rule remain readable without an overlay."
identity_accent = Color(0.90, 0.72, 0.28, 1)
