[ext_resource type="Script" path="res://scripts/crafting/crafted_item_effect_data.gd" id="1"]

[resource]
script = ExtResource("1")
item_id = &"ash_filter"
effect_kind = &"ash_protection"
action_label = "FIT FILTER"
use_summary = "Cuts ash exposure by 65 percent for three minutes while crossing contaminated ground."
