[ext_resource type="Script" path="res://scripts/crafting/crafted_item_effect_data.gd" id="1"]

[resource]
script = ExtResource("1")
item_id = &"circuit_bridge"
effect_kind = &"bridge"
action_label = "BRIDGE CIRCUIT"
use_summary = "Bypasses one dead relay, breaker or door circuit long enough to restore its function."
consequence = "The bridge welds itself across the contacts. The repaired route stays live, including anything listening on it."
