[gd_resource type="Resource" script_class="MemoryEchoData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/echoes/memory_echo_data.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"echo_mara_repair"
title = "Maggie's Service Ledger"
category = "Ashmere Estate"
quality = "Analogue record"
hint = "Greasy fingerprints stop at one job number, written twice."
memory_text = "WARD, M. Receiver fault at Ashmere workshop. Replaced F3 with a fuse borrowed from the clinic fridge. Wrenfield key moved to two-part check: lunch-tin mark plus job 6142. In the margin: 'Leena - I owe you a fuse, three insulin pens and an apology.'"
keepsake_item = &"tin_locket"
