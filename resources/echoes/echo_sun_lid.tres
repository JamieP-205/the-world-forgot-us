[gd_resource type="Resource" script_class="MemoryEchoData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/echoes/memory_echo_data.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"echo_sun_lid"
title = "The Sun on the Lunch Tin"
category = "Ashmere Estate"
quality = "Personal recording"
hint = "Yellow enamel shows through the soot. A sun has been scratched into the lid."
memory_text = "MAGGIE: 'Mum drew one sun because you said the yellow was boring.' A child objects that it has nine rays, not eight. 'Fine. Nine. Put your inhaler inside and do not swap tins with Callum again.' The voice is ordinary enough to hurt."
keepsake_item = &""
