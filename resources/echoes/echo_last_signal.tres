[gd_resource type="Resource" script_class="MemoryEchoData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/echoes/memory_echo_data.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"echo_last_signal"
title = "Mast Call, 02:13"
category = "Cullbrook Services"
quality = "Damaged recording"
hint = "A call is caught under the fallen mast's automatic warning."
memory_text = "MAGGIE: 'Ellie Ward. Eight. Red coat, blue inhaler in the left pocket.' Control says Ellie's record is already closed: caller confirmed safe. Maggie answers, 'She is holding my hand and she has not spoken to you.' The channel cuts while she is still reading the details. A photograph is folded inside the radio casing."
keepsake_item = &"old_photo"
