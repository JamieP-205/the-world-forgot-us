[gd_resource type="Resource" script_class="MemoryEchoData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/echoes/memory_echo_data.gd" id="1_echo"]

[resource]
script = ExtResource("1_echo")
id = &"echo_names_wall"
title = "The Names We Carried"
category = "Places"
quality = "Restored Memory"
hint = "Hundreds of scratched names wait beneath soot and signal frost."
memory_text = "Relay workers read names into the emergency band after the official records went blank. Teachers. Drivers. Infants. Strangers. Each name made the wall glow for a heartbeat. The final hand added two more: MARA VENN. ELLIE VENN. Someone here chose remembrance even when nobody promised rescue."
keepsake_item = &""
