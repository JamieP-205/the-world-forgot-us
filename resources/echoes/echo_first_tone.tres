[gd_resource type="Resource" script_class="MemoryEchoData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/echoes/memory_echo_data.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"echo_first_tone"
title = "Incident 44, 02:17"
category = "Tollard Exchange"
quality = "System record"
hint = "A printer jam preserved the report the database later replaced."
memory_text = "CONTINUITY MODE is filling damaged caller records with generated speech. Personalized routes now contradict road control. Immediate shutdown requested by O. Pryce, network duty engineer. COUNTY CONTROL: request denied while evacuation channels remain active. The attached test page records a synthetic Maggie Ward at 02:03; the official activation time is 02:17. Handwritten below: 'It was already speaking.'"
keepsake_item = &""
