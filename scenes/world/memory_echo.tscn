[sub_resource type="Shader" id="Shader_afterimage"]
code = "shader_type canvas_item;\nrender_mode unshaded;\n\nuniform float alignment : hint_range(0.0, 1.0) = 0.0;\nuniform float motion_strength : hint_range(0.0, 1.0) = 1.0;\nuniform vec4 trace_tone : source_color = vec4(0.54, 0.74, 0.66, 1.0);\n\nvoid fragment() {\n\tfloat clock = TIME * motion_strength;\n\tfloat fault_line = smoothstep(0.86, 0.98, 0.5 + 0.5 * sin(UV.y * 117.0 + clock * 4.1));\n\tfloat unsettled = 1.0 - alignment;\n\tfloat shear = sin(UV.y * 31.0 + clock * 2.7) * fault_line * (0.008 * unsettled + 0.0012 * motion_strength);\n\tvec2 sample_uv = clamp(UV + vec2(shear, 0.0), vec2(0.002), vec2(0.998));\n\tvec4 source = texture(TEXTURE, sample_uv);\n\tfloat luma = dot(source.rgb, vec3(0.299, 0.587, 0.114));\n\tvec3 paper_memory = mix(vec3(luma), source.rgb, 0.42);\n\tvec3 memory_detail = pow(max(paper_memory, vec3(0.0)), vec3(0.72));\n\tvec3 remembered_colour = memory_detail * mix(vec3(1.0), trace_tone.rgb, 0.30);\n\tremembered_colour = mix(remembered_colour, memory_detail, alignment * 0.28);\n\tfloat dropout = mix(0.82 + 0.18 * sin(UV.y * 173.0 + clock * 3.3), 1.0, alignment);\n\tCOLOR = vec4(remembered_colour * 1.20, source.a * dropout) * COLOR;\n}\n"

