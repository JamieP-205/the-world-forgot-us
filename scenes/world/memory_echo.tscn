[sub_resource type="Shader" id="Shader_artifact_detail"]
code = "shader_type canvas_item;\n\nuniform float shadow_lift : hint_range(0.0, 1.0) = 0.0;\nuniform float exposure : hint_range(0.4, 1.8) = 1.0;\n\nvoid fragment() {\n\tvec4 source = texture(TEXTURE, UV);\n\tfloat gamma = mix(1.0, 0.42, shadow_lift);\n\tvec3 lifted = pow(max(source.rgb, vec3(0.0)), vec3(gamma)) * exposure;\n\tCOLOR = vec4(lifted, source.a) * COLOR;\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_artifact_detail"]
